# Supabase — copy to .env.local and fill in after provisioning a project.
# Browser-safe (exposed to client). Anon key is protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser / never prefix with NEXT_PUBLIC.
# Bypasses RLS — used only by trusted server code (admin lib, extraction worker).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Anthropic (Claude) — server-only. Used by the AI chat route and crisis classifier.
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Admin authz allowlist (AD-5) for the aggregate-only /admin/metrics dashboard.
# Comma-separated, case-insensitive email addresses of signed-in users allowed
# to view aggregate quality/quantity metrics. NOT an auth.uid() RLS policy —
# a plain app-level check in lib/metrics/admin-auth.ts. Server-only.
ADMIN_EMAILS=admin@example.com
